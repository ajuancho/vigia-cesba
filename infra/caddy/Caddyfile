# Caddy reverse proxy para producción (EC2 + Docker Compose).
# TLS automático contra Let's Encrypt.
#
# Montado por docker-compose.prod.yml:
#   caddy:
#     image: caddy:2
#     ports: ["80:80", "443:443"]
#     volumes:
#       - ./infra/caddy/Caddyfile:/etc/caddy/Caddyfile:ro
#       - caddy_data:/data

vigia-api.openarg.org {
	# Security headers (la API solo se sirve por HTTPS detrás de Caddy).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# No filtrar el stack del upstream.
		-Server
	}
	reverse_proxy api:8000
	encode gzip
}
