# Caddy reverse proxy para producción (EC2 + Docker Compose).
# TLS automático contra Let's Encrypt.
#
# Montado por docker-compose.prod.yml:
#   caddy:
#     image: caddy:2
#     ports: ["80:80", "443:443"]
#     volumes:
#       - ./infra/caddy/Caddyfile:/etc/caddy/Caddyfile:ro
#       - caddy_data:/data

vigia-api.openarg.org {
	reverse_proxy api:8000
	encode gzip
}
