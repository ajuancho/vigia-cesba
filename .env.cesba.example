# ══════════════════════════════════════════════════════════════════
# Monitor Normativo CABA — CESBA
# Configuración de producción
#
# Copiar a .env y completar los valores marcados con <...>
# Generar AUTH_SECRET: openssl rand -hex 32
# ══════════════════════════════════════════════════════════════════

# ───────────────────────── Jurisdicción ─────────────────────────
# Acota TODAS las queries de la API al corpus porteño.
# No modificar: este es el valor correcto para la instancia CESBA.
VIGIA_JURISDICCION_SCOPE=CABA

# ───────────────────────── Database ─────────────────────────────
POSTGRES_USER=bocba
POSTGRES_PASSWORD=<password seguro>
POSTGRES_DB=bocba
DATABASE_URL=postgresql+asyncpg://bocba:<password>@<host_postgres>:5432/bocba

# ───────────────────────── Redis ────────────────────────────────
REDIS_URL=redis://<host_redis>:6379/0

# ───────────────────────── API ──────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Dominio del frontend (para CORS). Ajustar al dominio final del CESBA.
API_CORS_ORIGINS=https://normativa.cesba.gob.ar

# ───────────────────────── Web ──────────────────────────────────
NEXT_PUBLIC_API_URL=https://normativa-api.cesba.gob.ar
INTERNAL_API_URL=http://api:8000
# Activar cuando esté configurado el OAuth (ver sección Auth abajo)
NEXT_PUBLIC_AUTH_ENABLED=false

# ─────────────────── Auth + multi-tenant ────────────────────────
# Secreto para firmar JWT (HS256). Generar con: openssl rand -hex 32
AUTH_SECRET=<openssl rand -hex 32>

# Google OAuth — credenciales del proyecto GCP del CESBA/GCBA
# Authorized origin:   https://normativa.cesba.gob.ar
# Redirect URI:        https://normativa.cesba.gob.ar/api/auth/callback/google
AUTH_GOOGLE_ID=<google oauth client id>
AUTH_GOOGLE_SECRET=<google oauth client secret>

# false = modo demo abierto (recomendado para el piloto interno)
# true  = requiere login para acceder al feed y buscador
AUTH_ENABLED=false

# ─────────────────── Alertas / email ────────────────────────────
# Resend (https://resend.com) o AWS SES.
# Vacío → las alertas se registran en la DB pero no envían email.
RESEND_API_KEY=<resend api key>
ALERTS_FROM_EMAIL=BOCBA Monitor <alertas@cesba.gob.ar>
WEB_BASE_URL=https://normativa.cesba.gob.ar

# Email para alertas operativas (fuente stale, errores de ingesta).
# Opcional — si no se define, solo queda en /health/sources.
OPS_ALERT_EMAIL=<email del equipo técnico CESBA>

# ─────────────────── IA — resúmenes ─────────────────────────────
# off       → no-op (resumen_ia queda NULL — recomendado para el piloto)
# bedrock   → AWS Bedrock (credenciales por IAM role del EC2)
# anthropic → API directa de Anthropic (requiere ANTHROPIC_API_KEY)
VIGIA_AI_PROVIDER=off
# AWS_REGION=us-east-1
# AWS_BEDROCK_MODEL_HAIKU=us.anthropic.claude-haiku-4-5-20251001-v1:0
# ANTHROPIC_API_KEY=

# ───────────────────────── Observabilidad ───────────────────────
SENTRY_DSN=
VIGIA_ENV=production

# Retención de audit_log en días (Ley 25.326 art. 4)
VIGIA_AUDIT_RETENTION_DAYS=365

# ───────────────────────── Trial ────────────────────────────────
# Días de acceso antes de requerir membresía manual.
# Para herramienta interna sin trial, poner un valor alto.
VIGIA_TRIAL_DAYS=3650
