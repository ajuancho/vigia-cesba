# ─────────── Producción (backend en EC2) — copiar a .env.production ───────────
# NUNCA commitear .env.production. Cargar secretos desde AWS Secrets Manager.

# Postgres (RDS Postgres 16 con pgvector). Para EC2 all-in-one usar el host 'db'.
DATABASE_URL=postgresql+asyncpg://vigia:CHANGEME@vigia-db.xxxx.us-east-1.rds.amazonaws.com:5432/vigia
# Para el perfil local-data (db en compose):
POSTGRES_USER=vigia
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=vigia

# Redis (ElastiCache). Para EC2 all-in-one usar 'redis://redis:6379/0'.
REDIS_URL=redis://vigia-redis.xxxx.cache.amazonaws.com:6379/0

# API
API_CORS_ORIGINS=https://vigia.legal,https://www.vigia.legal

# Auth (Fase 2). AUTH_SECRET: openssl rand -hex 32. Compartido API↔web.
AUTH_ENABLED=true
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Alertas / email. Dominio openarg.org VERIFICADO en Resend (DKIM/SPF en
# Route53). La key NUNCA va al repo: cargarla a mano en el .env del EC2.
RESEND_API_KEY=
ALERTS_FROM_EMAIL=Vigía <alertas@openarg.org>
# Links en emails de alertas/invitaciones:
WEB_BASE_URL=https://vigia.openarg.org
# Incidentes de frescura de fuentes (check_sources):
OPS_ALERT_EMAIL=

# Retención de audit_log (IP/user-agent) en días — Ley 25.326 art. 4.
# Task semanal vigia_workers.maintenance.purge_audit_log. Default 365.
VIGIA_AUDIT_RETENTION_DAYS=365

# Observabilidad
SENTRY_DSN=

# Tag de imagen a desplegar (lo setea CI; default latest)
VIGIA_TAG=latest
