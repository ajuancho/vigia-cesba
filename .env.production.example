# ─────────── Producción (backend en EC2) — copiar a .env.production ───────────
# NUNCA commitear .env.production. Cargar secretos desde AWS Secrets Manager.

# Postgres (RDS Postgres 16 con pgvector). Para EC2 all-in-one usar el host 'db'.
DATABASE_URL=postgresql+asyncpg://vigia:CHANGEME@vigia-db.xxxx.us-east-1.rds.amazonaws.com:5432/vigia
# Para el perfil local-data (db en compose):
POSTGRES_USER=vigia
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=vigia

# Redis (ElastiCache). Para EC2 all-in-one usar 'redis://redis:6379/0'.
REDIS_URL=redis://vigia-redis.xxxx.cache.amazonaws.com:6379/0

# API
API_CORS_ORIGINS=https://vigia.legal,https://www.vigia.legal

# Auth (Fase 2). AUTH_SECRET: openssl rand -hex 32. Compartido API↔web.
AUTH_ENABLED=true
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Alertas / email (Fase 3)
RESEND_API_KEY=
ALERTS_FROM_EMAIL=alertas@vigia.legal

# Observabilidad
SENTRY_DSN=

# Tag de imagen a desplegar (lo setea CI; default latest)
VIGIA_TAG=latest
