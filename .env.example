# ───────────────────────── Database ─────────────────────────
POSTGRES_USER=vigia
POSTGRES_PASSWORD=vigia
POSTGRES_DB=vigia
DATABASE_URL=postgresql+asyncpg://vigia:vigia@localhost:5432/vigia

# ───────────────────────── Redis ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ───────────────────────── API ──────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# ───────────────────────── Web ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Flag público que enciende los controles de login/workspace en el web.
# Poner en true cuando configures Google OAuth abajo.
NEXT_PUBLIC_AUTH_ENABLED=false
# Internal URL the web uses for server-to-server calls (e.g. in docker compose).
# Falls back to NEXT_PUBLIC_API_URL when unset.
INTERNAL_API_URL=http://localhost:8000

# ─────────────────── Fase 2 — Auth + multi-tenant ───────────
# Shared secret used to:
#  - sign/verify the JWT issued by /auth/sync (HS256)
#  - authorize server-to-server calls from the web (NextAuth -> API)
# 32+ random bytes (e.g. `openssl rand -hex 32`).
AUTH_SECRET=

# Google OAuth (set both to flip the web from demo mode to gated)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Flip the API into gated mode. When false (default) -> modo demo abierto.
AUTH_ENABLED=false

# ─────────────────── Fase 3 — Alertas / email ──────────────
# Resend o AWS SES. Vacío -> las alertas se registran pero no envían email.
RESEND_API_KEY=
ALERTS_FROM_EMAIL=alertas@vigia.legal

# ───────────────────────── Observabilidad ───────────────────
SENTRY_DSN=

# ─────────────────── Fase 5 (futuro) — IA ──────────────────
# AWS_REGION=us-east-1
# ANTHROPIC_API_KEY=
