# ───────────────────────── Database ─────────────────────────
POSTGRES_USER=vigia
POSTGRES_PASSWORD=vigia
POSTGRES_DB=vigia
DATABASE_URL=postgresql+asyncpg://vigia:vigia@localhost:5432/vigia

# ───────────────────────── Redis ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ───────────────────────── API ──────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# ───────────────────────── Web ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Flag público que enciende los controles de login/workspace en el web.
# Poner en true cuando configures Google OAuth abajo.
NEXT_PUBLIC_AUTH_ENABLED=false
# Internal URL the web uses for server-to-server calls (e.g. in docker compose).
# Falls back to NEXT_PUBLIC_API_URL when unset.
INTERNAL_API_URL=http://localhost:8000

# ─────────────────── Fase 2 — Auth + multi-tenant ───────────
# Shared secret used to:
#  - sign/verify the JWT issued by /auth/sync (HS256)
#  - authorize server-to-server calls from the web (NextAuth -> API)
# 32+ random bytes (e.g. `openssl rand -hex 32`).
AUTH_SECRET=

# Google OAuth (set both to flip the web from demo mode to gated)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Flip the API into gated mode. When false (default) -> modo demo abierto.
AUTH_ENABLED=false

# ─────────────────── Fase 3 — Alertas / email ──────────────
# Resend o AWS SES. Vacío -> las alertas se registran pero no envían email.
RESEND_API_KEY=
ALERTS_FROM_EMAIL=alertas@vigia.legal

# ───────────────────────── Observabilidad ───────────────────
SENTRY_DSN=

# ─────────────────── IA — resúmenes (resumen_ia) ───────────
# La ingesta del Boletín Oficial genera un resumen en lenguaje claro por norma
# (campo resumen_ia, mostrado como "Análisis automático"). Stack: AWS Bedrock,
# calcando la convención del lab (ver ../investarg). Off por default.
#   off       -> no-op (la ingesta sigue igual, resumen_ia queda NULL)
#   bedrock   -> AWS Bedrock (credenciales por IAM / rol del EC2)
#   anthropic -> API directa de Anthropic (fallback; requiere ANTHROPIC_API_KEY)
# VIGIA_AI_PROVIDER=off
AWS_REGION=us-east-1
# Perfil de inferencia Bedrock (Claude 4.x exige el inference profile regional,
# no el id pelado). Verificado ACTIVE en la cuenta del lab; alternativa global.
AWS_BEDROCK_MODEL_HAIKU=us.anthropic.claude-haiku-4-5-20251001-v1:0
# Fallback API directa (solo si VIGIA_AI_PROVIDER=anthropic):
# ANTHROPIC_API_KEY=
# VIGIA_AI_MODEL=claude-haiku-4-5

# Retención de audit_log (IP/user-agent) en días — Ley 25.326 art. 4.
# La task semanal vigia_workers.maintenance.purge_audit_log borra lo más viejo.
# VIGIA_AUDIT_RETENTION_DAYS=365
